PREFIX altr-ext: <http://www.w3.org/ns/dx/connegp/altr-ext#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX prez: <https://prez.dev/>
PREFIX prof: <http://www.w3.org/ns/dx/prof/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://example.com/graph/profiles> {
    # top-level profile for specifying default profiles
    prez:IndexProfile
        a prof:Profile , prez:IndexProfile ;
        dcterms:identifier "index"^^xsd:token ;
        dcterms:description "A system profile for OGC Records conformant API" ;
        dcterms:title "Index Profile" ;
        altr-ext:constrainsClass prez:CatPrez ;
        altr-ext:hasDefaultResourceFormat "text/anot+turtle" ;
        altr-ext:hasResourceFormat
            "application/ld+json",
            "application/anot+ld+json",
            "application/rdf+xml",
            "text/anot+turtle",
            "text/turtle" ;
        altr-ext:hasNodeShape
            [
                a sh:NodeShape ;
                sh:targetClass
                    dcat:Catalog ,
                    dcat:Resource ,
                    skos:Concept ,
                    skos:Collection ,
                    rdf:Resource ,
                    prez:SearchResult ,
                    prez:CQLFilterResult ;
                altr-ext:hasDefaultProfile prez:OGCListingProfile
            ],
            [
                a sh:NodeShape ;
                sh:targetClass skos:ConceptScheme ;
                altr-ext:hasDefaultProfile prez:ConceptSchemesListProfile
            ],
            [
                a sh:NodeShape ;
                sh:targetClass skos:ConceptScheme ;
                altr-ext:hasDefaultProfile prez:OGCSchemesObjectProfile
            ],
            [
                a sh:NodeShape ;
                sh:targetClass skos:Collection ;
                altr-ext:hasDefaultProfile prez:OGCSKOSCollectionObjectProfile
            ],
            [
                a sh:NodeShape ;
                sh:targetClass
                    dcat:Catalog,
                    dcat:Resource,
                    skos:Concept ,
                    rdf:Resource ;
                altr-ext:hasDefaultProfile prez:OGCItemProfile
            ]
    .

    # regular profiles

    prez:ConceptSchemesListProfile
        a prof:Profile, prez:ListingProfile, sh:NodeShape ;
        dcterms:title "Concept Scheme Listing Profile" ;
        dcterms:description "A profile for listing SKOS Concept Schemes" ;
        dcterms:identifier "concept-schemes-listing"^^xsd:token ;
        altr-ext:hasResourceFormat
            "application/ld+json",
            "application/anot+ld+json",
            "application/rdf+xml",
            "text/anot+turtle",
            "text/turtle" ;
        altr-ext:hasDefaultResourceFormat "text/anot+turtle" ;
        altr-ext:constrainsClass skos:ConceptScheme , prez:CQLFilterResult ;
        sh:property [
            sh:path [
                sh:union (
                    schema:status
                    dcat:theme
                )
            ]
        ] ;
    .
}